# LLM Provider: rule-based | ollama | groq | openai
LLM_PROVIDER=rule-based

# Override base URL (optional — defaults filled per provider)
# Ollama default:  http://localhost:11434/v1
# Groq default:    https://api.groq.com/openai/v1
LLM_BASE_URL=

# API key (not needed for Ollama or rule-based)
LLM_API_KEY=

# Model override (optional)
# Ollama default:  llama3
# Groq default:    llama3-8b-8192
LLM_MODEL=
